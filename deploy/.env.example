# =============================================================================
# GC Pallet — production environment file
# =============================================================================
# 1. Copy this file to `.env` in the same directory.
# 2. Fill in the values below.
# 3. Run `docker compose -f deploy/docker-compose.yml up -d` from the repo root.
# =============================================================================

# Public DNS name pointing at this VM. Caddy uses it for the TLS cert
# (Let's Encrypt HTTP-01 challenge requires DNS to be live first).
DOMAIN=gcpallet.example.com

# PocketBase superuser. Created via the /_/ admin UI the first time
# the backend container is up. After that, the bootstrap container uses
# these creds to create the rest of the collections.
ADMIN_EMAIL=admin@example.com
# Minimum 10 characters. The init-vm.sh script generates a strong one
# automatically; only set this manually if you skipped that step.
ADMIN_PASSWORD=change-me-min-10-chars

# Baked into the frontend bundle at build time. Must match what the
# browser will use to reach the SDK (i.e. the public origin, NOT the
# internal docker hostname). The init script auto-fills this from DOMAIN.
NEXT_PUBLIC_PB_URL=https://gcpallet.example.com

# =============================================================================
# Optional — only required for daily backups to OCI Object Storage
# =============================================================================
# OCI_BUCKET_NAME=gcpallet-backups
# OCI_NAMESPACE=<your-tenancy-namespace; `oci os ns get`>
# OCI_COMPARTMENT_ID=<your-compartment-ocid>
# BACKUP_RETENTION_DAYS=14
